# GradConnectAI runtime configuration (minimal, in-use variables only)
# Copy to config/app.env and edit values.

########################################
# Shared / frontend
########################################
NEXT_PUBLIC_API_BASE=http://localhost:8009

########################################
# Backend - environment and logging
########################################
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

########################################
# Backend - API limits
########################################
API_RATE_LIMIT_PER_MINUTE=60
API_RATE_LIMIT_UPLOAD_PER_MINUTE=10
MAX_CV_FILE_SIZE_MB=5

########################################
# Backend - database
########################################
SYNC_DATABASE_URL=postgresql://PLACEHOLDER_USER:PLACEHOLDER_PASSWORD@PLACEHOLDER_HOST:5432/PLACEHOLDER_DB

########################################
# Backend - embeddings
########################################
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Optional: e.g. cuda:0, cpu, mps
EMBEDDING_DEVICE=
OLLAMA_BASE_URL=http://localhost:11434

########################################
# Backend - LLM
########################################
# For Ollama OpenAI compatibility: http://localhost:11434/v1
# For vLLM OpenAI compatibility:   http://localhost:8010/v1
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=EMPTY
LLM_MODEL=Qwen/Qwen3.5-0.8B

# LLM tuning
LLM_MAX_INPUT_CHARS=200000
LLM_MAX_OUTPUT_TOKENS_TOPICS=256
LLM_MAX_OUTPUT_TOKENS_PROFESSORS=2048
LLM_MAX_OUTPUT_TOKENS_EMAIL=768

########################################
# Backend - discovery crawling
########################################
CRAWL4AI_HEADLESS=1
CRAWL4AI_FORCE_HEADLESS_IF_NO_DISPLAY=1
GOOGLE_BROWSER_HEADLESS=1
GOOGLE_BROWSER_TIMEOUT_MS=30000
GOOGLE_BROWSER_WAIT_MS=1200
LINKEDIN_SESSION_TTL_MINUTES=120
LINKEDIN_MAX_RESULTS_PER_QUERY=10
# Optional LinkedIn auth cookie value for authenticated discovery
LINKEDIN_LI_AT=
# Optional full LinkedIn Cookie header (recommended if li_at alone is insufficient)
# Example: li_at=...; JSESSIONID=...; liap=true; bcookie="..."
LINKEDIN_COOKIE_HEADER=
LINKEDIN_BROWSER_HEADLESS=1
LINKEDIN_BROWSER_TIMEOUT_MS=30000
LINKEDIN_BROWSER_SCROLL_STEPS=4
LINKEDIN_BROWSER_SCROLL_WAIT_MS=1200
# Search provider policy (order matters: brave,google,bing,bing_rss,duckduckgo)
SEARCH_PROVIDER_ORDER=brave,bing,bing_rss,duckduckgo
# Comma-separated proxy URLs for rotation, example:
# SEARCH_PROXY_URLS=http://user:pass@proxy1:8000,http://user:pass@proxy2:8000
SEARCH_PROXY_URLS=
SEARCH_ENABLE_GOOGLE=0
SEARCH_GOOGLE_COOLDOWN_SECONDS=300

########################################
# Backend - browser-use AI agent
########################################
# Override Ollama model for browser-use agent (defaults to LLM_MODEL)
BROWSER_USE_OLLAMA_MODEL=
# Max LLM steps per search query (higher = more thorough but slower)
BROWSER_USE_MAX_STEPS=20
# Time filter for search results: day, week, month, year
BROWSER_USE_TIME_FILTER=month
