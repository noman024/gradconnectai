########################################
# Backend environment example (.env.example)
# Copy this file to `.env` and replace
# all PLACEHOLDER_ values with real ones.
########################################

# Database (e.g. Supabase or local Postgres)
# Async URL for migrations / scripts
DATABASE_URL=postgresql+asyncpg://PLACEHOLDER_USER:PLACEHOLDER_PASSWORD@PLACEHOLDER_HOST:5432/PLACEHOLDER_DB
# Sync URL used by the main app
SYNC_DATABASE_URL=postgresql://PLACEHOLDER_USER:PLACEHOLDER_PASSWORD@PLACEHOLDER_HOST:5432/PLACEHOLDER_DB

# Optional: Ollama base URL (no /v1 suffix)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding model name used by sentence-transformers
EMBEDDING_MODEL=PLACEHOLDER_EMBEDDING_MODEL   # e.g. nomic-embed-text

# OpenAI-compatible LLM.
# Examples:
#   Ollama: LLM_BASE_URL=http://localhost:11434/v1  LLM_MODEL=frob/qwen3.5-instruct:4b
#   vLLM:   LLM_BASE_URL=http://localhost:8001/v1   LLM_MODEL=Qwen/Qwen3.5-0.8B
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=EMPTY                                 # or PLACEHOLDER_API_KEY for hosted LLMs
LLM_MODEL=PLACEHOLDER_LLM_MODEL

# App
# Generate your own secret for a real deployment (e.g. `openssl rand -hex 32`)
API_SECRET_KEY=CHANGE_ME_SECRET_KEY
ENVIRONMENT=development

# CORS origins for frontend URLs (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Crawl4AI browser mode: 1=headless (default), 0=show browser window
CRAWL4AI_HEADLESS=1

# Logging
# LOG_LEVEL can be DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Rate limiting (crawler)
CRAWLER_REQUESTS_PER_MINUTE=30
CRAWLER_GLOBAL_REQUESTS_PER_MINUTE=120

# Retention (GDPR)
CV_RETENTION_DAYS=365
MATCH_RETENTION_DAYS=730
EMAIL_DRAFT_RETENTION_DAYS=90
