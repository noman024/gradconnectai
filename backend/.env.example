# Database (Supabase)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/postgres
SYNC_DATABASE_URL=postgresql://user:password@host:5432/postgres

# Optional: Ollama for local LLM
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# OpenAI-compatible LLM. Use Ollama on Mac (recommended) or vLLM with GPU.
# Ollama: LLM_BASE_URL=http://localhost:11434/v1  LLM_MODEL=qwen3.5:0.8b
# vLLM:   LLM_BASE_URL=http://localhost:8001/v1  LLM_MODEL=Qwen/Qwen3.5-0.8B
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=EMPTY
LLM_MODEL=qwen3.5:0.8b

# App
API_SECRET_KEY=your-secret-key-change-in-production
ENVIRONMENT=development

# Crawl4AI browser mode: 1=headless (default), 0=show browser window
CRAWL4AI_HEADLESS=1

# Logging
# LOG_LEVEL can be DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Rate limiting (crawler)
CRAWLER_REQUESTS_PER_MINUTE=30
CRAWLER_GLOBAL_REQUESTS_PER_MINUTE=120

# Retention (GDPR)
CV_RETENTION_DAYS=365
MATCH_RETENTION_DAYS=730
EMAIL_DRAFT_RETENTION_DAYS=90
